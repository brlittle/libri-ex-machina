# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string
# Neon:     postgresql://user:pass@host/dbname?sslmode=require
# Railway:  postgresql://postgres:pass@host:port/railway
# Local:    postgresql://postgres:postgres@localhost:5432/uigen
DATABASE_URL=""

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Long random string used to sign session JWTs
# Generate one: openssl rand -base64 48
JWT_SECRET=""
